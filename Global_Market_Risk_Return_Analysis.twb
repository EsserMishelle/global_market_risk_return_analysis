    <dashboard name='Global Market Risk, Return, and Sentiment Analysis Story' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='15'>Global Market Risk, Return, and Sentiment Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='573' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98478' id='1' param='vert' removable='false' type-v2='layout-flow' w='99206' x='397' y='761'>
            <zone h='3330' id='3' type-v2='title' w='99206' x='397' y='761' />
            <zone h='9610' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99206' x='397' y='4091' />
            <zone h='85538' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99206' x='397' y='13701'>
              <flipboard active-id='6' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Global market behavior varies substantially across asset classes, creating distinct patterns in performance, risk efficiency, and sentiment metrics.' captured-sheet='Gloabl Market Risk Dashboard' id='1'>
                    <capturedDeltas>
                      <worksheet name='Market Sentiment by Asset Class'>
                        <selection-collection />
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Quadrant analysis reveals clear separation between high-efficient global markets and weaker-performing asset classes with lower return stability.' captured-sheet='Risk-Adjusted Returns by Asset Class' id='2' />
                  <story-point caption='Return horizon analysis highlights stronger long-term performance in international and Index markets, while shorter-term weakness remains concentrated in Cypto, and US Mid Cap assets.' captured-sheet='Return Horizons vs. Sharpe by Asset Class' id='3' />
                  <story-point caption='Market remains heavily concentrated in Greed and Neutral sentiments across most asset classes, with ETF and US Mega Cap markets exhibiting the strongest bullish mementum and Crypto and US Mid Cap displaying the most uncertainty and Fear exposure. ' captured-sheet='Market Sentiment by Asset Class' id='4' />
                  <story-point caption='Higher composite scores are concentrated within various US Mega Cap and International sectors, indicating stronger balance between return potential. and risk-adjusted stability.' captured-sheet='Composite Score by Asset Class and Sector' id='5' />
                  <story-point captured-sheet='' id='6' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='50618' id='6' story-point-id='6' type-v2='text' w='50050' x='18304' y='26070'>
          <formatted-text>
            <run bold='true'>Conclusion:</run>
            <run>Æ&#10;</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>·       International and ETF markets exhibit the strongest risk-adjusted performance Crypto remained the weakest and most volatile asset class.</run>
            <run fontalignment='0'>Æ&#10;&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>·       Diversified global markets demonstrated stronger long-term efficiency and stability than higher-volatility assets.</run>
            <run fontalignment='0'>Æ&#10;&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>·       Market performance varied significantly across asset classes, indicating the importance of balancing return with volatility.</run>
            <run fontalignment='0'>Æ&#10;&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontsize='10'>·       Composite scoring and sentiment analysis exhibit stronger performance concentration withing diversified equity markets. </run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{67509B31-EF32-4495-A4A3-0BEBEE52FDEC}' />
    </dashboard>
  </dashboards>
